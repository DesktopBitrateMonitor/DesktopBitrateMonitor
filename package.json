{
  "name": "desktop-bitrate-monitor",
  "version": "0.0.5",
  "description": "An app to listen for SRT(LA) stream stats and change scenes in a broadcasting software",
  "main": "./out/main/index.js",
  "author": "yinks87",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
