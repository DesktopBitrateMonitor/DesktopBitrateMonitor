    "@legendapp/state": "^2.1.15",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/x-charts": "^8.27.5",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "i18next": "^25.7.3",
    "i18next-http-backend": "^3.0.2",
    "obs-websocket-js": "^5.0.8",
    "react-grid-layout": "^2.2.2",
    "react-i18next": "^16.5.0",
    "react-router-dom": "^7.10.1",
    "ws": "^8.18.3"
